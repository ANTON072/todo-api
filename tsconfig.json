{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "types": ["@types/node"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "src",
    "scripts",
    "tests",
    "*.ts",
    "*.d.ts",
    "node_modules/@cloudflare/vitest-pool-workers/types/cloudflare-test.d.ts"
  ]
}
