{
  "name": "todo-api",
  "private": true,
  "scripts": {
    "dev": "node --env-file=.env --watch --import tsx src/server.ts",
    "test": "vitest run",
    "check": "biome check --write",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "gen:schema": "tsx scripts/generate-openapi.ts > docs/openapi.json"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.8.0",
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "better-auth": "^1.6.20",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26",
    "postgres": "^3.4.9",
    "resend": "^6.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^26.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
